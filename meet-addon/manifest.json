{
  "manifest_version": 3,
  "name": "Meet & Calendar Checker",
  "version": "1.0.0",
  "description": "Verifica y abre Google Meet y Google Calendar si no están abiertos.",
  "permissions": [
    "tabs",
    "storage",
    "offscreen",
    "tts",
    "alarms"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://calendar.google.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
